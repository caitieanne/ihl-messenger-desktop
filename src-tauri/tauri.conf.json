{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IHL Messenger",
  "version": "0.1.1",
  "identifier": "live.industryhub.messenger",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "IHL Messenger",
        "url": "https://industryhub.live/messenger-app",
        "width": 420,
        "height": 720,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "IHL Messenger"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "IHL Messenger",
    "longDescription": "The IHL Messenger desktop app — buddy lists, statuses, nudges, and chat for the IndustryHub community.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
